<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns="http://autosar.org/schema/r4.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://autosar.org/schema/r4.0 AUTOSAR_00048.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>AdaptiveProject</SHORT-NAME>
      <ELEMENTS>
        <SERVICE-INTERFACE>
          <SHORT-NAME>RadarService</SHORT-NAME>
          <NAMESPACES>
            <SYMBOL-PROPS>
              <SHORT-NAMEE>radar</SHORT-NAMEE>
              <SYMBOL>radar</SYMBOL>
            </SYMBOL-PROPS>
          </NAMESPACES>
          <EVENTS>
            <VARIABLE-DATA-PROTOTYPE>
              <SHORT-NAME>ObjectDetected</SHORT-NAME>
              <TYPE-TREF DEST="STD-CPP-IMPLEMENTATION-DATA-TYPE">/DataTypes/Cpp/uint32</TYPE-TREF>
            </VARIABLE-DATA-PROTOTYPE>
          </EVENTS>
        </SERVICE-INTERFACE>

        <ADAPTIVE-APPLICATION-SW-COMPONENT-TYPE>
          <SHORT-NAME>RadarApplication</SHORT-NAME>
          <PORTS>
            <P-PORT-PROTOTYPE>
              <SHORT-NAME>RadarOut</SHORT-NAME>
              <PROVIDED-INTERFACE-TREF DEST="SERVICE-INTERFACE">/AdaptiveProject/RadarService</PROVIDED-INTERFACE-TREF>
            </P-PORT-PROTOTYPE>
          </PORTS>
        </ADAPTIVE-APPLICATION-SW-COMPONENT-TYPE>
      </ELEMENTS>
    </AR-PACKAGE>
    
    <AR-PACKAGE>
      <SHORT-NAME>DataTypes</SHORT-NAME>
      <AR-PACKAGES>
        <AR-PACKAGE>
          <SHORT-NAME>Cpp</SHORT-NAME>
          <ELEMENTS>
            <STD-CPP-IMPLEMENTATION-DATA-TYPE>
              <SHORT-NAME>uint32</SHORT-NAME>
              <CATEGORY>VALUE</CATEGORY>
            </STD-CPP-IMPLEMENTATION-DATA-TYPE>
          </ELEMENTS>
        </AR-PACKAGE>
      </AR-PACKAGES>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>